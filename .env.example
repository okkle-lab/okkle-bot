# Copy this file to .env for local development (Railway uses its Variables tab instead).

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to Haiku 4.5 (cheapest model with vision).
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Messaging transport ---
# "auto" (default): use Twilio when its credentials are set below, else a no-op
# console backend that just prints. Set "console" to force the no-account
# backend for local dev, or "twilio" to require Twilio.
MESSAGING_PROVIDER=auto

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Sandbox sender to start with; swap for your own number once approved.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- URLs ---
# The exact public URL Twilio calls (used to verify webhook signatures).
WEBHOOK_URL=https://your-app.up.railway.app/webhook/whatsapp
# Base URL used to build CSV download links.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# --- Database ---
# Railway injects this automatically when you add Postgres. Leave blank locally
# to fall back to a SQLite file (./courier.db).
# DATABASE_URL=

# Below this confidence, the courier is warned to check the figures.
CONFIDENCE_WARN_THRESHOLD=0.6
